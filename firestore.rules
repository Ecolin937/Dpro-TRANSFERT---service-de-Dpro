rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    // Validation Helper for Transfer
    function isValidTransfer(data) {
      return data.keys().hasAll(['fileName', 'fileSize', 'fileType', 'downloadUrl', 'createdAt', 'expiresAt', 'ownerId', 'storagePath'])
        && data.keys().size() == 8
        && data.fileName is string && data.fileName.size() >= 1 && data.fileName.size() <= 512
        && data.fileSize is number && data.fileSize > 0 && data.fileSize <= 5368709120
        && data.fileType is string && data.fileType.size() <= 128
        && data.downloadUrl is string && data.downloadUrl.size() <= 2048
        && data.createdAt == request.time
        && data.expiresAt is timestamp && data.expiresAt > request.time
        && data.ownerId == request.auth.uid
        && data.storagePath is string && data.storagePath.size() <= 1024;
    }

    match /transfers/{transferId} {
      // Identity Integrity & Path Hardening
      allow get: if isValidId(transferId);
      
      // Strict List Denial (No blanket reads)
      allow list: if false;

      allow create: if isSignedIn() 
        && isValidId(transferId)
        && isValidTransfer(incoming());

      // Transfers are immutable by users after creation
      allow update: if false;

      // Allow deletion by owner
      allow delete: if isSignedIn() 
        && existing().ownerId == request.auth.uid;
    }
  }
}
