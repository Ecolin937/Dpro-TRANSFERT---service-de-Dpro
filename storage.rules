rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /transfers/{userId}/{transferId}/{fileName} {
      // Allow read for everyone (to allow download via download URL)
      allow read: if true;
      
      // Allow write if authenticated and size <= 5GB
      allow create: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size <= 5 * 1024 * 1024 * 1024;
      
      // Allow delete if owner
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
